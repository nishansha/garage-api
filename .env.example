# Copy this to `.env` on the server and fill in real values.
# Do NOT commit the real `.env`.

POSTGRES_DB=garage
POSTGRES_USER=garage
POSTGRES_PASSWORD=change-me-strong-password

# Generate with: openssl rand -base64 32
APP_JWT_SECRET=change-me-base64-32-bytes

# Comma-separated list of origins allowed to call the API (scheme + host, no path).
# Production:
APP_CORS_ALLOWED_ORIGINS=https://triasoft-garage.duckdns.org

# Optional JVM tuning. Defaults are fine for a 1–2 GB VM.
# JAVA_OPTS=-Xms256m -Xmx512m

# Public domain this server is reachable at (bare hostname, no scheme/path).
# Must have a DNS A/AAAA record already pointing at this box's public IP —
# caddy uses it to request a Let's Encrypt certificate on first start.
DOMAIN=garage.yourdomain.com

# Optional: email Let's Encrypt sends certificate-expiry/problem notices to.
# Uncomment and add an `email {$ACME_EMAIL}` global block in Caddyfile to use it.
# ACME_EMAIL=you@yourdomain.com
