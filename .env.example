# Copy this to `.env` on the server and fill in real values.
# Do NOT commit the real `.env`.

POSTGRES_DB=garage
POSTGRES_USER=garage
POSTGRES_PASSWORD=change-me-strong-password

# Generate with: openssl rand -base64 32
APP_JWT_SECRET=change-me-base64-32-bytes

# Comma-separated list of origins allowed to call the API.
# Example: https://garage.yourdomain.com,https://app.yourdomain.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:8081

# Optional JVM tuning. Defaults are fine for a 1–2 GB VM.
# JAVA_OPTS=-Xms256m -Xmx512m
